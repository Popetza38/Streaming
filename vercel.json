{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/download",
      "destination": "/api/download"
    },
    {
      "source": "/sb-proxy",
      "destination": "/api/proxy?action=sb-proxy"
    },
    {
      "source": "/derive-key",
      "destination": "/api/proxy?action=derive-key"
    },
    {
      "source": "/img",
      "destination": "/api/proxy?action=img"
    },
    {
      "source": "/video",
      "destination": "/api/video"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/proxy"
    }
  ]
}