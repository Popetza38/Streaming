{
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/download",
      "destination": "/api/download"
    },
    {
      "source": "/video",
      "destination": "/api/video"
    },
    {
      "source": "/api/:path*",
      "destination": "/api/proxy"
    }
  ]
}